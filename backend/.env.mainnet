# =============================================
# Mainnet-Konfiguration
# Aktivieren: cp .env.mainnet .env && systemctl restart smartc-app
# =============================================

NETWORK=mainnet
RPC_URL=http://10.10.10.102:8545

# Deployer-Wallet (Adresse in docs/wallets.md)
DEPLOYER_PRIVATE_KEY=<PRIVATE_KEY_AUS_WALLETS_MD>

PORT=3000
DEPLOYMENTS_FILE=/root/smartc/backend/data/deployments-mainnet.json
CONTRACT_ARTIFACTS_DIR=/root/smartc/contracts/out
