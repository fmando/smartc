# =============================================
# XCB Smart Contract App – Konfiguration
# cp .env.example .env  –  .env ist in .gitignore!
# =============================================

PORT=3000

# Startup-Netzwerk: testnet | mainnet
# Kann zur Laufzeit über POST /api/network/switch geändert werden
NETWORK=testnet

# ──────────────────────────────────────────
# Testnet – Devín (Network ID 3, AB-Prefix)
# ──────────────────────────────────────────
TESTNET_RPC_URL=http://127.0.0.1:8545

# Signing-Modus 1 (empfohlen): Ed448 Private Key (57 Bytes = 114 Hex-Zeichen)
TESTNET_DEPLOYER_PRIVATE_KEY=

# Signing-Modus 2 (Fallback, nur für lokale Nodes mit personal API):
TESTNET_DEPLOYER_ADDRESS=
TESTNET_DEPLOYER_PASSWORD=

# ──────────────────────────────────────────
# Mainnet (Network ID 1, CB-Prefix)
# ──────────────────────────────────────────
MAINNET_RPC_URL=http://10.10.10.102:8545

# Signing: Ed448 Private Key (local signing, personal API nicht nötig)
MAINNET_DEPLOYER_PRIVATE_KEY=

DEPLOYMENTS_FILE=/root/smartc/backend/data/deployments.json
CONTRACT_ARTIFACTS_DIR=/root/smartc/contracts/out
